# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT (RS256 public key only, escaped with \n)
JWT_PUBLIC_KEY=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Internal API key (must match auth-service)
INTERNAL_API_KEY=change_this_to_a_long_random_secret

# Downstream services
AUTH_SERVICE_URL=http://localhost:3001
STUDENT_SERVICE_URL=http://localhost:3002
ACADEMIC_SERVICE_URL=http://localhost:3013
FINANCE_SERVICE_URL=http://localhost:3014
NOTIFICATION_SERVICE_URL=http://localhost:3005
ANALYTICS_SERVICE_URL=http://localhost:3416

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=60
LOGIN_THROTTLE_TTL=900
LOGIN_THROTTLE_LIMIT=10

# Proxy timeout (ms)
PROXY_TIMEOUT_MS=30000
