PORT=3000
NODE_ENV=development

# JWT (RS256 public key from auth-service, escaped with \n)
JWT_PUBLIC_KEY=

# Downstream service URLs
AUTH_SERVICE_URL=http://localhost:3001
STUDENT_SERVICE_URL=http://localhost:3002
ACADEMIC_SERVICE_URL=http://localhost:3003
FINANCE_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005
ANALYTICS_SERVICE_URL=http://localhost:3006

# Internal API key (must match auth-service INTERNAL_API_KEY)
INTERNAL_API_KEY=change_this_to_a_long_random_secret

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
