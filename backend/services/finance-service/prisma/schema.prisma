generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["finance"]
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  WAIVED

  @@schema("finance")
}

enum PaymentMethod {
  MOBILE_MONEY
  BANK_TRANSFER
  CASH
  WAIVER
  SCHOLARSHIP
  OTHER

  @@schema("finance")
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
  REFUNDED
  CANCELLED

  @@schema("finance")
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED

  @@schema("finance")
}

enum ApprovalDecision {
  APPROVED
  REJECTED

  @@schema("finance")
}

enum FinancialAuditAction {
  FEE_CATEGORY_CREATED
  FEE_CATEGORY_UPDATED
  FEE_CATEGORY_DEACTIVATED
  FEE_STRUCTURE_CREATED
  FEE_STRUCTURE_UPDATED
  FEE_STRUCTURE_DEACTIVATED
  INVOICE_GENERATED
  INVOICE_ISSUED
  INVOICE_CANCELLED
  INVOICE_WAIVED
  INVOICE_DISCOUNT_APPLIED
  STUDENT_FEE_ASSIGNED
  STUDENT_FEE_REMOVED
  PAYMENT_RECORDED
  PAYMENT_CONFIRMED
  PAYMENT_REJECTED
  PAYMENT_REFUNDED
  MANUAL_PAYMENT_APPROVED
  MANUAL_PAYMENT_REJECTED
  RECEIPT_ISSUED
  RECEIPT_VOIDED
  ASSET_CREATED
  ASSET_UPDATED
  ASSET_DISPOSED

  @@schema("finance")
}

enum AssetCategory {
  FURNITURE
  ELECTRONICS
  VEHICLE
  BUILDING
  EQUIPMENT
  LABORATORY
  LIBRARY
  SPORTS
  OTHER

  @@schema("finance")
}

enum AssetType {
  FIXED
  MOVABLE

  @@schema("finance")
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CONDEMNED

  @@schema("finance")
}

enum AssetStatus {
  ACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  LOST
  STOLEN

  @@schema("finance")
}

model FeeCategory {
  id               String               @id @default(uuid())
  name             String               @unique
  code             String               @unique
  description      String?
  isOptional       Boolean              @default(true)
  isBillablePerTerm Boolean             @default(true)
  isActive         Boolean              @default(true)
  displayOrder     Int                  @default(0)
  createdById      String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  updatedById      String?
  feeStructures    FeeStructure[]
  assignments      StudentFeeAssignment[]
  lineItems        InvoiceLineItem[]

  @@index([isActive, displayOrder])
  @@schema("finance")
}

model FeeStructure {
  id             String             @id @default(uuid())
  feeCategoryId  String
  classId        String?
  classLevel     Int?
  academicYearId String
  termId         String?
  amount         Decimal            @db.Decimal(12, 2)
  currency       String             @default("TZS")
  isActive       Boolean            @default(true)
  effectiveFrom  DateTime           @default(now())
  effectiveTo    DateTime?
  createdById    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  updatedById    String?
  feeCategory    FeeCategory        @relation(fields: [feeCategoryId], references: [id], onDelete: Restrict)
  lineItems      InvoiceLineItem[]

  @@unique([feeCategoryId, classId, termId, academicYearId])
  @@index([classId, termId, academicYearId])
  @@index([classLevel, termId, academicYearId])
  @@schema("finance")
}

model StudentFeeAssignment {
  id             String      @id @default(uuid())
  studentId      String
  feeCategoryId  String
  academicYearId String
  termId         String?
  isActive       Boolean     @default(true)
  assignedById   String
  assignedAt     DateTime    @default(now())
  notes          String?
  feeCategory    FeeCategory @relation(fields: [feeCategoryId], references: [id], onDelete: Restrict)

  @@unique([studentId, feeCategoryId, academicYearId, termId])
  @@index([studentId, academicYearId])
  @@schema("finance")
}

model Invoice {
  id                 String          @id @default(uuid())
  invoiceNumber      String          @unique
  studentId          String
  classId            String
  academicYearId     String
  termId             String
  subtotal           Decimal         @db.Decimal(12, 2)
  discountAmount     Decimal         @default(0) @db.Decimal(12, 2)
  discountReason     String?
  totalAmount        Decimal         @db.Decimal(12, 2)
  paidAmount         Decimal         @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal         @db.Decimal(12, 2)
  currency           String          @default("TZS")
  status             InvoiceStatus   @default(DRAFT)
  dueDate            DateTime
  issuedAt           DateTime?
  issuedById         String?
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?
  waivedAt           DateTime?
  waivedById         String?
  waiverReason       String?
  pdfUrl             String?
  academicCleared    Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  lineItems          InvoiceLineItem[]
  payments           Payment[]
  receipts           Receipt[]

  @@unique([studentId, termId, academicYearId])
  @@index([studentId, status])
  @@index([termId, status])
  @@index([dueDate, status])
  @@schema("finance")
}

model InvoiceLineItem {
  id              String      @id @default(uuid())
  invoiceId       String
  feeStructureId  String
  feeCategoryId   String
  feeCategoryName String
  amount          Decimal     @db.Decimal(12, 2)
  currency        String      @default("TZS")
  isPaid          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  invoice         Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  feeStructure    FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Restrict)
  feeCategory     FeeCategory @relation(fields: [feeCategoryId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@schema("finance")
}

model Payment {
  id               String         @id @default(uuid())
  paymentNumber    String         @unique
  invoiceId        String
  studentId        String
  amount           Decimal        @db.Decimal(12, 2)
  currency         String         @default("TZS")
  method           PaymentMethod
  status           PaymentStatus
  referenceNumber  String?
  payerName        String?
  payerPhone       String?
  paidAt           DateTime?
  confirmedAt      DateTime?
  confirmedById    String?
  rejectedAt       DateTime?
  rejectedById     String?
  rejectionReason  String?
  refundedAt       DateTime?
  refundedById     String?
  refundReason     String?
  requiresApproval Boolean        @default(false)
  approvalStatus   ApprovalStatus?
  approvedAt       DateTime?
  approvedById     String?
  notes            String?
  ipAddress        String?
  webhookPayload   Json?
  receiptId        String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  invoice          Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  receipt          Receipt?       @relation("PaymentReceipt")
  manualApproval   ManualPaymentApproval?

  @@index([invoiceId])
  @@index([studentId, status])
  @@index([status, requiresApproval])
  @@index([referenceNumber])
  @@schema("finance")
}

model Receipt {
  id             String        @id @default(uuid())
  receiptNumber  String        @unique
  paymentId      String        @unique
  invoiceId      String
  studentId      String
  studentName    String
  classId        String
  termId         String
  academicYearId String
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("TZS")
  method         PaymentMethod
  referenceNumber String?
  paidAt         DateTime
  issuedAt       DateTime      @default(now())
  issuedById     String
  pdfUrl         String?
  isVoided       Boolean       @default(false)
  voidedAt       DateTime?
  voidedById     String?
  voidReason     String?
  createdAt      DateTime      @default(now())
  payment        Payment       @relation("PaymentReceipt", fields: [paymentId], references: [id], onDelete: Restrict)
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([paymentId])
  @@schema("finance")
}

model ManualPaymentApproval {
  id                  String           @id @default(uuid())
  paymentId           String           @unique
  requestedById       String
  requestedAt         DateTime         @default(now())
  reviewedById        String?
  reviewedAt          DateTime?
  decision            ApprovalDecision?
  rejectionReason     String?
  notes               String?
  supportingDocumentUrl String?
  payment             Payment          @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@schema("finance")
}

model FinancialAuditLog {
  id              String               @id @default(uuid())
  entityType      String
  entityId        String
  action          FinancialAuditAction
  performedById   String
  performedByRole String
  previousValue   Json?
  newValue        Json?
  metadata        Json?
  ipAddress       String?
  createdAt       DateTime             @default(now())

  @@index([entityId, entityType])
  @@index([performedById])
  @@index([createdAt])
  @@schema("finance")
}

model Asset {
  id                 String         @id @default(uuid())
  assetNumber        String         @unique
  name               String
  description        String?
  category           AssetCategory
  type               AssetType
  serialNumber       String?
  brand              String?
  model              String?
  purchaseDate       DateTime?
  purchaseCost       Decimal?       @db.Decimal(12, 2)
  currentValue       Decimal?       @db.Decimal(12, 2)
  currency           String         @default("TZS")
  location           String?
  condition          AssetCondition
  status             AssetStatus
  assignedTo         String?
  warrantyExpiryDate DateTime?
  disposalDate       DateTime?
  disposalReason     String?
  disposalValue      Decimal?       @db.Decimal(12, 2)
  photoUrl           String?
  notes              String?
  createdById        String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  updatedById        String?

  @@index([status, category])
  @@schema("finance")
}

model NumberSequence {
  id       String  @id
  year     Int
  value    Int     @default(0)
  updatedAt DateTime @updatedAt

  @@schema("finance")
}
