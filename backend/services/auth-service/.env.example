# App
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgress:Mtunzi123@localhost:5432/kilimanjaro_db?schema=auth

# JWT (RSA keys - keep escaped newlines)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Internal API key
INTERNAL_API_KEY=change_this_to_a_long_random_secret

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=60
LOGIN_THROTTLE_TTL=900
LOGIN_THROTTLE_LIMIT=10
