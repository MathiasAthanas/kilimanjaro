# App
NODE_ENV=development
PORT=3005
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgress:Mtunzi123@localhost:5432/kilimanjaro_db?schema=notifications

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# Internal API Key
INTERNAL_API_KEY=change_this_to_a_long_random_secret

# Downstream Services
AUTH_SERVICE_URL=http://localhost:3001
STUDENT_SERVICE_URL=http://localhost:3002

# SMS Provider (africastalking | beem | twilio | generic)
SMS_PROVIDER=africastalking
SMS_SENDER_ID=KILIMANJARO

# Africa's Talking
AT_API_KEY=
AT_USERNAME=sandbox
AT_SANDBOX=true

# Beem Africa
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SOURCE_ADDR=KILIMANJARO

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Generic HTTP SMS Provider
SMS_GENERIC_URL=
SMS_GENERIC_METHOD=POST
SMS_GENERIC_AUTH_HEADER=Authorization
SMS_GENERIC_AUTH_VALUE=
SMS_GENERIC_PHONE_PARAM=to
SMS_GENERIC_MESSAGE_PARAM=message

# Email Provider (sendgrid | mailgun | smtp)
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=Kilimanjaro Schools <no-reply@kilimanjaro.ac.tz>
SENDGRID_API_KEY=
MAILGUN_USER=
MAILGUN_PASSWORD=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON=

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=60
